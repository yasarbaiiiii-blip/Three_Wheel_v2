# Mapbox public access token (starts with "pk.").
# Used by src/config/mapbox.ts via Mapbox.setAccessToken at runtime.
# Expo inlines EXPO_PUBLIC_* vars into the JS bundle at build time.
#
# Get/manage tokens at https://account.mapbox.com/access-tokens/
# Recommended: restrict this token (URL/bundle allowlist + rate limits) in the dashboard.
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.your_public_token_here
